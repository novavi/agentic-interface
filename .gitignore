# Belt-and-braces: exclude all .env* files everywhere; keep committed example templates
.env*
!.env.example
!.env.local.example

# ── frontend/ (Next.js) ────────────────────────────────────────────────────
frontend/node_modules/
frontend/.pnp
frontend/.pnp.*
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/.vercel/
